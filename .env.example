# =============================================
# GiftsNPrint Environment Configuration
# Copy this file to .env and fill in your values
# =============================================

# Server
PORT=3000
NODE_ENV=production

# Database (Get from Neon Dashboard)
DATABASE_URL=postgresql://user:password@hostname/db_name?sslmode=require

# JWT Secret (Use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Razorpay (Get from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Email (Use your business email SMTP)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=info.giftsnprint@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=GiftsNPrint <info.giftsnprint@gmail.com>
ADMIN_EMAIL=info.giftsnprint@gmail.com

# WhatsApp Business Number
WHATSAPP_NUMBER=91XXXXXXXXXX

# Site URL
SITE_URL=https://www.giftsnprint.com

# Admin Credentials (for initial setup)
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=ChangeMe@123
